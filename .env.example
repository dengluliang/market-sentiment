# ============================================
# Market Sentiment 环境变量配置
# 复制本文件为 .env 并填入你的真实值
# cp .env.example .env
# ============================================

# ---------- AI 模型 API Key ----------
# 方式一：Anthropic 官方 API（推荐 Claude Sonnet 4+）
ANTHROPIC_API_KEY=sk-ant-你的key

# 方式二：如果用自定义 provider，需要同时修改 opencode.json 中的 provider 配置
# CUSTOM_API_KEY=你的key
# CUSTOM_BASE_URL=https://你的代理地址/v1

# ---------- 飞书 MCP（可选） ----------
# 用于将报告输出到飞书文档
# 获取方式：访问 https://mcp.feishu.cn 创建你的 MCP 服务
# 如果不需要飞书输出，可以留空或从 opencode.json 删除 mcp 配置
FEISHU_MCP_URL=https://mcp.feishu.cn/mcp/你的MCP地址
